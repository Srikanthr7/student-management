# EduTrack Pro — Environment Variables
# Copy this file to .env and fill in your values

# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-here
WTF_CSRF_SECRET_KEY=your-csrf-secret-key-here

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here

# Database (leave blank for SQLite in dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/edutrack_db

# Admin Account
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@edutrackpro.com
DEFAULT_ADMIN_PASSWORD=Admin@123

# Email (optional – leave blank to use stub/log mode)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@edutrackpro.com

# Cloudinary (for persistent file/image storage)
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
